{
    "version": 2,
    "builds": [
      {
        "src": "backend/src/vercel.ts",
        "use": "@vercel/node"
      },
      {
        "src": "client/package.json",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "./dist"
        }
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/backend/src/vercel.ts"
      },
      {
        "src": "/(.*)",
        "dest": "./dist/$1"
      }
    ]
  }
  